{
  "name": "pill-taker-backend",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "packageManager": "npm@11.16.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run docker:up && npm run docker:attach",
    "docker:attach": "docker attach pill-taker",
    "docker:bash": "docker exec -it pill-taker bash",
    "docker:up": "docker compose -p pill-taker --env-file .env.development up -d --build --force-recreate",
    "build": "tsup src/index.ts --format esm",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "nodemailer": "^8.0.11",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.30.1",
    "msw": "^2.14.6",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
